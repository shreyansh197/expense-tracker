// ─────────────────────────────────────────────────────────────
// ExpenStream — Prisma Schema
// Account-Based Auth + Workspace Model
// PostgreSQL · soft-delete · JSONB · composite indexes
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════  USERS & AUTH  ═══════════════════

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique @db.VarChar(255)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz
  passwordHash    String?   @map("password_hash") @db.VarChar(255)
  totpSecret      String?   @map("totp_secret") @db.VarChar(64)
  totpEnabledAt   DateTime? @map("totp_enabled_at") @db.Timestamptz
  recoveryCodes   String[]  @default([]) @map("recovery_codes") @db.VarChar(20)
  name            String    @default("") @db.VarChar(120)
  avatarUrl       String?   @map("avatar_url") @db.Text
  googleId        String?   @unique @map("google_id") @db.VarChar(255)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  passkeys         Passkey[]
  memberships      Membership[]
  devices          Device[]
  sessions         Session[]
  invitesSent      Invite[]       @relation("InviteSender")
  deviceLinksOwned DeviceLink[]
  auditLogs        AuditLog[]
  ownedWorkspaces  Workspace[]    @relation("WorkspaceOwner")

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

// ═══════════════════════════  PASSKEYS (WebAuthn)  ════════════

model Passkey {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  credentialId        String   @unique @map("credential_id") @db.Text
  credentialPublicKey Bytes    @map("credential_public_key")
  counter             BigInt   @default(0)
  transports          String[] @default([]) @db.VarChar(20)
  deviceName          String   @default("") @map("device_name") @db.VarChar(120)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  lastUsedAt          DateTime @default(now()) @map("last_used_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}

// ═══════════════════════════  WORKSPACES  ═════════════════════

model Workspace {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String  @default("My Expenses") @db.VarChar(120)
  ownerId        String  @map("owner_id") @db.Uuid
  /// Legacy sync code for migration. NULL for new workspaces.
  legacySyncCode String? @unique @map("legacy_sync_code") @db.VarChar(10)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  owner              User                @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships        Membership[]
  devices            Device[]
  invites            Invite[]
  deviceLinks        DeviceLink[]
  expenses           Expense[]
  workspaceSettings  WorkspaceSettings?
  businessLedgers    BusinessLedger[]
  businessPayments   BusinessPayment[]
  syncCursors        SyncCursor[]

  @@index([ownerId])
  @@map("workspaces")
}

// ═══════════════════════════  MEMBERSHIP  ═════════════════════

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model Membership {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  workspaceId String     @map("workspace_id") @db.Uuid
  role        MemberRole @default(MEMBER)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

// ═══════════════════════════  DEVICES  ════════════════════════

model Device {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  workspaceId  String    @map("workspace_id") @db.Uuid
  clientId     String?   @map("client_id") @db.VarChar(64)
  name         String    @default("Unknown Device") @db.VarChar(120)
  platform     String    @default("web") @db.VarChar(40)
  userAgent    String?   @map("user_agent") @db.VarChar(512)
  lastActiveAt DateTime  @default(now()) @map("last_active_at") @db.Timestamptz
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sessions  Session[]

  @@index([userId])
  @@index([workspaceId])
  @@index([revokedAt])
  @@map("devices")
}

// ═══════════════════════════  SESSIONS  ═══════════════════════

model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  deviceId         String    @map("device_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(128)
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  ipHash           String?   @map("ip_hash") @db.VarChar(64)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([expiresAt])
  @@map("sessions")
}

// ═══════════════════════════  INVITES  ════════════════════════

model Invite {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String     @map("workspace_id") @db.Uuid
  inviterId   String     @map("inviter_id") @db.Uuid
  tokenHash   String     @unique @map("token_hash") @db.VarChar(128)
  role        MemberRole @default(MEMBER)
  expiresAt   DateTime   @map("expires_at") @db.Timestamptz
  usedAt      DateTime?  @map("used_at") @db.Timestamptz
  revokedAt   DateTime?  @map("revoked_at") @db.Timestamptz
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter   User      @relation("InviteSender", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([expiresAt])
  @@map("invites")
}

// ═══════════════════════════  DEVICE LINKS  ═══════════════════

model DeviceLink {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash") @db.VarChar(128)
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz
  usedAt      DateTime? @map("used_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([expiresAt])
  @@map("device_links")
}

// ═══════════════════════════  AUDIT LOG  ══════════════════════

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.VarChar(64)
  action     String   @db.VarChar(30)
  meta       Json?    @db.JsonB
  ipHash     String?  @map("ip_hash") @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ═══════════════════════════  DOMAIN: EXPENSES  ═══════════════

model Expense {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  category    String    @db.VarChar(60)
  amount      Decimal   @db.Decimal(14, 2)
  currency    String?   @db.VarChar(3)
  day         Int       @db.SmallInt
  month       Int       @db.SmallInt
  year        Int       @db.SmallInt
  remark      String?   @db.VarChar(255)
  isRecurring Boolean   @default(false) @map("is_recurring")
  recurringId String?   @map("recurring_id") @db.VarChar(64)
  version     Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, month, year])
  @@index([workspaceId, updatedAt])
  @@index([workspaceId, deletedAt])
  @@map("expenses")
}

// ═══════════════════════════  DOMAIN: WORKSPACE SETTINGS  ═════

model WorkspaceSettings {
  workspaceId         String   @id @map("workspace_id") @db.Uuid
  salary              Decimal  @default(0) @db.Decimal(14, 2)
  currency            String   @default("INR") @db.VarChar(3)
  categories          Json     @default("[]") @db.JsonB
  customCategories    Json     @default("[]") @map("custom_categories") @db.JsonB
  hiddenDefaults      Json     @default("[]") @map("hidden_defaults") @db.JsonB
  categoryBudgets     Json     @default("{}") @map("category_budgets") @db.JsonB
  recurringExpenses   Json     @default("[]") @map("recurring_expenses") @db.JsonB
  savedFilters        Json     @default("[]") @map("saved_filters") @db.JsonB
  goals               Json     @default("[]") @db.JsonB
  rolloverEnabled     Boolean  @default(false) @map("rollover_enabled")
  rolloverHistory     Json     @default("{}") @map("rollover_history") @db.JsonB
  businessMode        Boolean  @default(false) @map("business_mode")
  revenueExpectations Json     @default("[]") @map("revenue_expectations") @db.JsonB
  businessTags        Json     @default("[]") @map("business_tags") @db.JsonB
  multiCurrencyEnabled Boolean @default(false) @map("multi_currency_enabled")
  dashboardLayout     Json?    @map("dashboard_layout") @db.JsonB
  dismissedRecurringSuggestions Json @default("[]") @map("dismissed_recurring_suggestions") @db.JsonB
  autoRules           Json     @default("[]") @map("auto_rules") @db.JsonB
  version             Int      @default(1)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_settings")
}

// ═══════════════════════════  DOMAIN: BUSINESS LEDGERS  ═══════

model BusinessLedger {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  name           String    @db.VarChar(200)
  expectedAmount Decimal   @map("expected_amount") @db.Decimal(14, 2)
  currency       String    @default("INR") @db.VarChar(3)
  status         String    @default("active") @db.VarChar(20)
  dueDate        DateTime? @map("due_date") @db.Date
  tags           Json      @default("[]") @db.JsonB
  notes          String    @default("") @db.Text
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  payments  BusinessPayment[]

  @@index([workspaceId, status])
  @@index([workspaceId, updatedAt])
  @@map("business_ledgers")
}

// ═══════════════════════════  DOMAIN: BUSINESS PAYMENTS  ══════

model BusinessPayment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  ledgerId    String    @map("ledger_id") @db.Uuid
  amount      Decimal   @db.Decimal(14, 2)
  date        DateTime  @db.Date
  method      String?   @db.VarChar(30)
  reference   String?   @db.VarChar(200)
  notes       String?   @db.Text
  version     Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ledger    BusinessLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)

  @@index([workspaceId, ledgerId])
  @@index([workspaceId, updatedAt])
  @@map("business_payments")
}

// ═══════════════════════════  SYNC CURSORS (per device)  ══════

model SyncCursor {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  deviceId    String   @map("device_id") @db.VarChar(64)
  tableName   String   @map("table_name") @db.VarChar(60)
  cursor      DateTime @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, deviceId, tableName])
  @@map("sync_cursors")
}

