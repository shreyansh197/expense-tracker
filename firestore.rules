rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user isolation: each user can only access their own data
    match /users/{userId}/expenses/{expenseId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.amount is number
                    && request.resource.data.amount > 0
                    && request.resource.data.category is string
                    && request.resource.data.day is number
                    && request.resource.data.month is number
                    && request.resource.data.year is number;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && (request.resource.data.amount is number
                        && request.resource.data.amount > 0);
      allow delete: if false; // Use soft-delete (deletedAt) instead
    }

    match /users/{userId}/settings/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
